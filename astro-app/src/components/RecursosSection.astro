---
interface Props {
  t: any;
}

const { t } = Astro.props;

const recursos = [
  {
    slug: 'foros-a-nichos-rentables',
    title: 'De Foros a Nichos Rentables en 14 Días',
    desc: 'Playbook para encontrar nichos con dolor real usando Reddit, G2 y comunidades.',
    tag: 'Playbook',
    color: '#6351d5',
  },
  {
    slug: 'cac-sostenible',
    title: 'El Sistema CAC Sostenible',
    desc: 'Cómo reducir tu CAC un 60% con el framework de 5 bloques.',
    tag: 'Framework',
    color: '#0faec1',
  },
  {
    slug: 'meseta-de-crecimiento',
    title: 'Romper la Meseta de Crecimiento',
    desc: 'Las 4 palancas para desbloquear tu crecimiento estancado.',
    tag: 'Framework',
    color: '#45b6f7',
  },
  {
    slug: 'david-vs-goliat',
    title: 'David vs Goliat',
    desc: 'Compite y gana con 10x menos presupuesto que tu competencia.',
    tag: 'Framework',
    color: '#22c55e',
  },
];
---

<section id="recursos" class="py-20 bg-slate-50 border-t border-slate-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#032149] mb-4 tracking-tight">
        Recursos gratuitos para crecer
      </h2>
      <p class="text-lg text-slate-600 max-w-xl mx-auto">
        Frameworks y playbooks probados con fintechs y SaaS reales. Sin teoría, sin fluff.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mb-10">
      {recursos.map((r) => (
        <a
          href={`/recursos/${r.slug}/`}
          class="group block bg-white rounded-xl border border-slate-200 hover:border-[#6351d5]/40 hover:shadow-lg transition-all duration-200 p-5"
        >
          <span
            class="inline-block px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider mb-3"
            style={`background:${r.color}18;color:${r.color}`}
          >
            {r.tag}
          </span>
          <h3 class="text-sm font-bold text-[#032149] mb-2 group-hover:text-[#6351d5] transition-colors leading-snug">
            {r.title}
          </h3>
          <p class="text-xs text-slate-500 leading-relaxed">
            {r.desc}
          </p>
        </a>
      ))}
    </div>

    <div class="text-center">
      <a
        href="/recursos/"
        class="inline-flex items-center gap-2 border-2 border-[#6351d5] text-[#6351d5] hover:bg-[#6351d5] hover:text-white font-bold py-3 px-8 rounded-full text-sm transition-all duration-300"
      >
        Ver todos los recursos
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
