---
import { TRUST_SCORE_URL } from '../lib/constants';

interface Props {
  t: any;
}

const { t } = Astro.props;

const pillars = [
  { icon: '🤝', name: 'Borrowed Trust', desc: 'Menciones y referencias de terceros' },
  { icon: '🔍', name: 'SERP Trust', desc: 'Presencia y posición en Google' },
  { icon: '🎨', name: 'Brand Assets', desc: 'Activos visuales y de marca' },
  { icon: '🤖', name: 'GEO Presence', desc: 'Visibilidad en IAs generativas' },
  { icon: '📣', name: 'Outbound Readiness', desc: 'Preparación para captar leads' },
  { icon: '⚡', name: 'Demand Engine', desc: 'Infraestructura de demanda' },
];
---

<section id="diagnostico" class="py-20 bg-gradient-to-br from-[#032149] to-[#0a1628] relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#0faec1]/5 rounded-full blur-3xl"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <!-- Header -->
    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-2 bg-[#0faec1]/15 text-[#0faec1] text-xs font-bold uppercase tracking-wider px-4 py-2 rounded-full mb-6">
        <span class="w-1.5 h-1.5 bg-[#0faec1] rounded-full animate-pulse"></span>
        Herramienta gratuita
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 tracking-tight">
        ¿Tu marca genera<br/>
        <span class="text-[#0faec1]">confianza digital</span>?
      </h2>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Descubre en 2 minutos cómo te perciben Google, las IAs y tus potenciales clientes. Analizamos 6 pilares de tu presencia digital y te damos un diagnóstico accionable.
      </p>
    </div>

    <!-- Two columns: CTA + Pillars -->
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <!-- Left: CTA card -->
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-[#0faec1]/20 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-[#0faec1]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <div>
            <h3 class="text-white font-bold text-lg">Trust Score Analyzer</h3>
            <p class="text-slate-400 text-sm">by Growth4U</p>
          </div>
        </div>

        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-3 text-slate-300 text-sm">
            <svg class="w-4 h-4 text-[#0faec1] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Sin registro previo — metes tu URL y listo
          </li>
          <li class="flex items-center gap-3 text-slate-300 text-sm">
            <svg class="w-4 h-4 text-[#0faec1] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Análisis con IA de 6 pilares de confianza
          </li>
          <li class="flex items-center gap-3 text-slate-300 text-sm">
            <svg class="w-4 h-4 text-[#0faec1] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Reporte completo por email en minutos
          </li>
          <li class="flex items-center gap-3 text-slate-300 text-sm">
            <svg class="w-4 h-4 text-[#0faec1] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Gaps, comparativa y recomendaciones concretas
          </li>
        </ul>

        <a
          href={TRUST_SCORE_URL}
          class="group flex items-center justify-center gap-2.5 w-full bg-[#0faec1] hover:bg-[#0d9ba8] text-white font-bold py-4 px-8 rounded-xl text-base shadow-lg shadow-[#0faec1]/20 hover:shadow-xl hover:shadow-[#0faec1]/25 transition-all duration-300"
        >
          Analizar mi marca gratis
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="text-center text-xs text-slate-500 mt-3">100% gratuito — resultado en menos de 2 minutos</p>
      </div>

      <!-- Right: Pillars grid -->
      <div class="grid grid-cols-2 gap-3">
        {pillars.map((p) => (
          <div class="bg-white/5 border border-white/10 rounded-xl p-4 hover:bg-white/10 hover:border-[#0faec1]/30 transition-all">
            <div class="text-2xl mb-2">{p.icon}</div>
            <div class="text-sm font-semibold text-white mb-1">{p.name}</div>
            <div class="text-xs text-slate-400">{p.desc}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Social proof line -->
    <div class="mt-12 flex items-center justify-center gap-6 text-xs text-slate-500">
      <span>El 81% de compradores B2B investiga online antes de decidir</span>
      <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
      <span>Las IAs ya recomiendan a tu competencia</span>
    </div>
  </div>
</section>
